# Environment Configuration
# Set to 'prod' or 'production' to use API data instead of mock data
VITE_ENVIRONMENT=development

# API Configuration
# In production, set this to your backend API URL
VITE_API_URL=https://api.lecabe.com.br

# Vercel Deployment (for GitHub Actions)
# Get these from Vercel dashboard
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_vercel_org_id_here
VERCEL_PROJECT_ID=your_vercel_project_id_here
